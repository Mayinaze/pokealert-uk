# PokeAlert UK — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Resend (email alerts) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of emails to alert
ALERT_RECIPIENTS=you@example.com,partner@example.com

# Supabase (optional — for future database integration)
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_KEY=eyJxxxxxxxxxxxxxxxx
