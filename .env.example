# PokeAlert UK — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Resend (email sending) — https://resend.com ──────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The verified sender address for all outgoing emails
ALERT_FROM_EMAIL=PokeAlert UK <alerts@yourdomain.com>

# ── Supabase (subscriber database) — https://supabase.com ───
# Use the SERVICE ROLE key here (scraper only — never expose in frontend)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJxxxxxxxx...

# ── Site config ───────────────────────────────────────────────
# Used to build unsubscribe links in emails
SITE_URL=https://pokealert.uk

# ── Optional fallback (if Supabase is not configured) ────────
# Comma-separated list of emails to alert (legacy — use Supabase instead)
# ALERT_RECIPIENTS=you@example.com,partner@example.com
