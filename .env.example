# PokeAlert UK — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── Supabase — https://supabase.com ──────────────────────────
# Use the SERVICE ROLE key (scraper only — never expose in frontend)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJxxxxxxxx...

# ── Pushover (stock alert notifications) — https://pushover.net ──
PUSHOVER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
PUSHOVER_USER=xxxxxxxxxxxxxxxxxxxxxxxxxx
